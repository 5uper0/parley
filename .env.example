# Parley voice layer — copy to .env and fill in. .env is gitignored; never commit real keys.

# The brain (live conversation). Unset → gateway uses the deterministic extractor.
OPENROUTER_API_KEY=
PARLEY_VOICE_MODEL=anthropic/claude-opus-4-8

# The gateway's own bearer secret (ElevenLabs sends it as the Custom-LLM Authorization).
PARLEY_GATEWAY_BEARER=

# Which decision + which party the agent represents.
PARLEY_VOICE_RECIPE=examples/demo/recipe_estate.json
PARLEY_VOICE_OWNER="Heir 2"

# Telephony (later — for the actual call). Zadarma SIP creds go in the ElevenLabs UI, not here.
# ELEVENLABS_API_KEY=
# ELEVENLABS_AGENT_ID=
# ELEVENLABS_PHONE_NUMBER_ID=
